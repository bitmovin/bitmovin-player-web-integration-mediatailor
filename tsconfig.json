{
  "files": ["src/ts/main.ts"],
  "compilerOptions": {
    "noImplicitAny": true,
    "module": "es6",
    "moduleResolution": "node",
    "target": "es5",
    "declaration": true,
    "outDir": "dist/js",
    "sourceMap": true,
    "lib": ["es2016", "es2015.promise", "dom"],
    "allowJs": false,
    "skipLibCheck": true,
    "types": ["node"],
  },
  "exclude": ["node_modules"],
  "include": ["src/**/*"]
}
